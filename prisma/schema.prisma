generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String
  price       Float
  images      String[]
  category    String   @default("Geral")
  stock       Int      @default(0)
  isFeatured  Boolean  @default(false)
  isPromo     Boolean  @default(false)
  promoPrice  Float?
  technicalSpecs String?
  condition   String   @default("Novo")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Admin {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  email    String @unique
  password String
}

model Settings {
  id               String @id @default(auto()) @map("_id") @db.ObjectId
  storeName        String @default("Premium Store")
  storeDescription String @default("A melhor experiência de compra")
  supportWhatsApp  String @default("5511999999999")
  premiumTheme     String @default("dark")
}
